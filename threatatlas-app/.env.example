# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=threatatlas
POSTGRES_PASSWORD=threatatlas_dev
POSTGRES_DB=threatatlas
POSTGRES_PORT=5432

# ── Backend API ───────────────────────────────────────────────────────────────
API_TITLE=ThreatAtlas API
API_VERSION=1.0.0
DEBUG=True

# ── Security ──────────────────────────────────────────────────────────────────
# IMPORTANT: Change SECRET_KEY to a long random string before deploying to production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# ── Ports ─────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Email / SMTP (required for invitation links) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@threatatlas.com
SMTP_FROM_NAME=ThreatAtlas
SMTP_TLS=True

# ── Invitations ───────────────────────────────────────────────────────────────
INVITATION_EXPIRE_HOURS=168
