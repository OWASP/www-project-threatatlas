# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://threatatlas:threatatlas_dev@localhost:5432/threatatlas

# ── Backend API ───────────────────────────────────────────────────────────────
API_TITLE=ThreatAtlas API
API_VERSION=1.0.0
DEBUG=True

# ── Security ──────────────────────────────────────────────────────────────────
# IMPORTANT: Change SECRET_KEY to a long random string before deploying to production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# ── Email / SMTP (required for invitation links) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@threatatlas.com
SMTP_FROM_NAME=ThreatAtlas
SMTP_TLS=True

# ── Invitations ───────────────────────────────────────────────────────────────
INVITATION_EXPIRE_HOURS=168
# Base URL for invitation links / redirects. Use http://localhost:3000 when running Vite (`pnpm dev`, default port).
FRONTEND_URL=http://localhost:3000
