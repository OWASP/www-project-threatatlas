# Database Configuration
DATABASE_URL=postgresql://threatatlas:threatatlas_dev@localhost:5433/threatatlas

# API Configuration
API_TITLE=ThreatAtlas API
API_VERSION=1.0.0
DEBUG=True

# Security
SECRET_KEY=your-secret-key-here-change-in-production

# CORS Origins - configured in code, defaults to http://localhost:5173 and http://localhost:3000

# Email Configuration (for invitations)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@threatatlas.com
SMTP_FROM_NAME=ThreatAtlas
SMTP_TLS=True

# Invitations
INVITATION_EXPIRE_HOURS=168
FRONTEND_URL=http://localhost:5173
